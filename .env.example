# =============================================
# LUMIA — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# =============================================

# Banco de dados
DATABASE_URL="postgresql://lumia:lumia_dev_123@localhost:5432/lumia?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="trocar-por-um-secret-forte-em-producao"
JWT_REFRESH_SECRET="trocar-por-outro-secret-forte-em-producao"

# Google Maps
GOOGLE_MAPS_API_KEY="sua-chave-google-maps"

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID="seu-project-id"
FIREBASE_PRIVATE_KEY="sua-private-key"

# Cloudinary (Upload de imagens)
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

# Servidor
PORT=3333
CLIENT_URL="http://localhost:5173"
